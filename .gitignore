# ML Model artifacts — exclude training outputs but KEEP saved-model/ (needed for inference)
# These are stored in ml-model/saved-model/ which is explicitly tracked
# *.pkl  ← intentionally NOT excluded (saved models are needed)
# *.pth  ← intentionally NOT excluded (handwriting_model.pth is needed)
*.h5
*.onnx
*.bin

# Training logs & temp scripts
ml-model/training/training_log.txt
ml-model/training/scan_healthy_folder.py

# Training datasets (raw images/audio — too large for git)
ml-model/training/handwriting_dataset/
ml-model/training/voice_dataset/
ml-model/training/gait_dataset/

# ===========================
# Uploads (runtime files)
# ===========================
# uploads/ contents are ignored via uploads/.gitignore
# The directory itself is tracked so the app has a place to save files on clone

